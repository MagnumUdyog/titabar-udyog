# Runtime (Vercel / serverless): transaction pooler on port 6543
# Dashboard "Shared Pooler" shows port 5432 (session) — use 6543 for deployed apps.
# URL-encode @ in password as %40 (e.g. @mypass → %40mypass)
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Migrations only (prisma db push / migrate): direct host, port 5432
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.PROJECT_REF.supabase.co:5432/postgres"

# Required on Vercel — random 32+ character string
SESSION_SECRET="change-this-to-a-long-random-secret-string"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
